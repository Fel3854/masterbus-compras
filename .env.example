# =============================================================================
# WEBSERVICE — Plantilla de credenciales
# Copiar como .env y completar con valores reales. NUNCA subir a git.
# =============================================================================

# Base de datos Supabase (connection string del Transaction Pooler)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Clave secreta para firmar las cookies de sesión (mínimo 32 chars aleatorios)
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# Entorno
DEBUG=false
LOG_LEVEL=INFO
